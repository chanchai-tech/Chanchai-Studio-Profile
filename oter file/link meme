<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>คลิกสิ...ถ้าคลิกทันนะ (Smooth Edition)</title>
                <style>
                        body {
                                    margin: 0;
                                                height: 100vh;
                                                            display: flex;
                                                                        justify-content: center;
                                                                                    align-items: center;
                                                                                                background-color: #ffffff;
                                                                                                            overflow: hidden;
                                                                                                                        font-family: 'Tahoma', sans-serif;
                                                                                                                                }
                                                                                                                                
                                                                                                                                        #runaway-btn {
                                                                                                                                                    padding: 15px 30px;
                                                                                                                                                                font-size: 18px;
                                                                                                                                                                            background-color: #ff4757; /* เปลี่ยนเป็นสีแดงให้ดูท้าทายขึ้น */
                                                                                                                                                                                        color: white;
                                                                                                                                                                                                    border: none;
                                                                                                                                                                                                                border-radius: 50px; /* ทำปุ่มมนๆ จะดูสมูทกว่า */
                                                                                                                                                                                                                            cursor: pointer;
                                                                                                                                                                                                                                        position: absolute;
                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                /* หัวใจหลักของความสมูท: ใช้ cubic-bezier เพื่อให้การเคลื่อนที่ดูเป็นธรรมชาติ */
                                                                                                                                                                                                                                                                            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                                                                                                                                                                                                                                                                                                                user-select: none; /* กันคนคลุมดำ (Highlight) ปุ่ม */
                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                #runaway-btn:hover {
                                                                                                                                                                                                                                                                                                                                            background-color: #ff6b81;
                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                        </style>
                                                                                                                                                                                                                                                                                                                                                        </head>
                                                                                                                                                                                                                                                                                                                                                        <body>
                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                            <button id="runaway-btn">คลิกที่นี่</button>
                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                <script>
                                                                                                                                                                                                                                                                                                                                                                        const btn = document.getElementById('runaway-btn');
                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                        // ระยะตรวจจับเมาส์ (ยิ่งเยอะปุ่มยิ่งรู้ตัวเร็ว)
                                                                                                                                                                                                                                                                                                                                                                                                const offset = 120; 
                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                        document.addEventListener('mousemove', (e) => {
                                                                                                                                                                                                                                                                                                                                                                                                                    const btnRect = btn.getBoundingClientRect();
                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                            // หาจุดกึ่งกลางปุ่ม
                                                                                                                                                                                                                                                                                                                                                                                                                                                        const btnCenterX = btnRect.left + btnRect.width / 2;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    const btnCenterY = btnRect.top + btnRect.height / 2;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                // คำนวณระยะห่าง
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            const distance = Math.hypot(e.clientX - btnCenterX, e.clientY - btnCenterY);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        if (distance < offset) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        // คำนวณทิศทางที่เมาส์วิ่งมา เพื่อให้ปุ่มหนีไปทิศตรงข้าม (จะดูฉลาดกว่าสุ่มมั่วๆ)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        const angle = Math.atan2(btnCenterY - e.clientY, btnCenterX - e.clientX);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        // กำหนดระยะการกระโดดหนี (150-200 pixels)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        const moveDist = 200;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let newX = btnRect.left + Math.cos(angle) * moveDist;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let newY = btnRect.top + Math.sin(angle) * moveDist;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        // เช็คไม่ให้ปุ่มหลุดขอบจอ
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        const padding = 10;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        newX = Math.max(padding, Math.min(newX, window.innerWidth - btnRect.width - padding));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        newY = Math.max(padding, Math.min(newY, window.innerHeight - btnRect.height - padding));
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        btn.style.left = `${newX}px`;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        btn.style.top = `${newY}px`;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            btn.onclick = () => {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        window.location.href = "https://www.youtube.com/watch?v=dQw4w9WgXcQ"; 
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                };
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </script>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </body>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </html>>